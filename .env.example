# --- resolve-mcp / director shared ---

# Required: GEMINI_API_KEY powers both Contextualizer (vision) and Planner/Director (reasoning).
# Never commit. resolve-mcp does NOT touch this — it lives in `director` only.
GEMINI_API_KEY=

# Gemini model ids (overridable so users can swap to flash/pro/whatever).
DIRECTOR_REASONING_MODEL=gemini-2.5-pro
DIRECTOR_VISION_MODEL=gemini-2.5-flash

# Run store location (used by `director`). Default: SQLite in the package data dir.
DIRECTOR_RUN_STORE=./runs

# --- resolve-mcp only ---

# Transport: "stdio" (default) or "http".
RESOLVE_MCP_TRANSPORT=stdio

# If "true", enable destructive tools (quit_app, restart_app, delete_timeline, delete_media).
# They ALSO require an explicit `confirm=true` argument; this flag is the global gate.
RESOLVE_MCP_ALLOW_DESTRUCTIVE=false

# --- DaVinci Resolve bootstrap (Windows / macOS) ---
# These three vars must be set OR the host must have them exported globally
# before launching the `resolve-mcp` server. See README.md "Resolve Bootstrap".
#
# Windows example (PowerShell):
#   $env:RESOLVE_SCRIPT_API  = "C:\Program Files\Blackmagic Design\DaVinci Resolve\Developer\Scripting\API"
#   $env:RESOLVE_SCRIPT_LIB  = "C:\Program Files\Blackmagic Design\DaVinci Resolve\Developer\Scripting\Lib\resolve_lite.exe"  # Studio: "...\DaVinci Resolve\..."
#   $env:PYTHONPATH          = $env:RESOLVE_SCRIPT_API
#
# Also, in DaVinci Resolve: Preferences -> General -> "External scripting using" = "Local"
# RESOLVE_SCRIPT_API=
# RESOLVE_SCRIPT_LIB=
# PYTHONPATH=
